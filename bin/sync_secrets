#!/usr/bin/env bash

set -eEuo pipefail

dry_run=0
op=""
args=()

for arg in "$@"; do
  case "$arg" in
    --dry-run|-n)
      dry_run=1
      ;;
    *)
      if [[ -z "$op" ]]; then
        op="$arg"
      else
        args+=("$arg")
      fi
      ;;
  esac
done

help() {
  cat <<EOT
./sync_secrets [--dry-run|-n] <push|pull|sync|list> [secret_name] [file_name]

Examples:
	./sync_secrets push asdf ./.secrets
  ./sync_secrets --dry-run push asdf ./.secrets
	
	./sync_secrets pull terraform ./terraform.tfvars
  ./sync_secrets -n pull terraform ./terraform.tfvars

  ./sync_secrets sync terraform ./terraform.tfvars
  ./sync_secrets --dry-run sync terraform ./terraform.tfvars

Config mode (no secret_name/file_name):
	Create ./.sync_secrets.toml with:

	[secrets]
	asdf = "./.secrets"
	terraform = "./terraform.tfvars"

	Then run:
	./sync_secrets push
	./sync_secrets pull
  ./sync_secrets sync
EOT
}

parse_sync_config() {
  local config_file="$1"
  local query='.secrets // {} | to_entries[] | .key + "\t" + (.value | tostring)'

  if yq --version 2>/dev/null | grep -qi "mikefarah"; then
    yq eval -p=toml -o=json -r "$query" "$config_file"
    return
  fi

  if command -v tomlq &>/dev/null; then
    tomlq -r "$query" "$config_file"
    return
  fi

  echo "Found Python yq, but 'tomlq' is missing for TOML parsing."
  echo "Install python-yq extras (tomlq) or use mikefarah/yq."
  return 1
}

# bw list items --raw --folderid "d48dbd5b-b683-4de8-8edc-ae0b00c1e25d"
bitwarden() {
  local op="$1"
  local arg_secret_name="${2:-}"
  local arg_file_name="${3:-}"
  local dry_run="${4:-0}"

  BW_SESSION=${BW_SESSION:-`bw unlock --raw`}
  export BW_SESSION=$BW_SESSION
  bw sync
  local folder="secrets"

  if ! bw get folder $folder &>/dev/null ; then
    echo "Creating $folder folder"
    local data=`echo -n "{\"name\": \"$folder\"}" | base64`
    bw create folder $data
  fi

  local folder_id=`bw get folder $folder | jq -r ".id"`

  if [[ "$op" == "list" ]]; then
    bw list items --raw --folderid "$folder_id" | jq -r ".[].name" | sed "s/^SECRET_//"
    exit 0
  fi

  get_item() {
    local secret_name="$1"
    bw list items --folderid "$folder_id" 2>/dev/null | jq -r "[.[] | select(.name==\"$secret_name\")] | first"
  }

  pull_one() {
    local secret_name="$1"
    local file_name="$2"

    echo "Pulling $secret_name from bitwarden"

    local item="$(get_item "$secret_name")"
    local id=`echo $item | jq -r ".id"`

    if [[ "$id" == "" ]] || [[ "$id" == "null" ]]; then
      echo "Secret '$secret_name' not found in folder '$folder'"
      return 1
    fi

    if [[ "$dry_run" -eq 1 ]]; then
      echo "[dry-run] Would pull '$secret_name' to '$file_name'"
      return 0
    fi

    local note=`bw get notes $id`

    if [[ "${#note}" -eq 0 ]]; then
      echo "Note empty pulling attachment"
      bw get attachment "$file_name" --itemid "$id"
      return 0
    fi

    echo -n "$note" > "$file_name"
    return 0
  }

  push_one() {
    local secret_name="$1"
    local file_name="$2"

    echo "Pushing '$file_name' as '$secret_name' to bitwarden"

    if [[ ! -f "$file_name" ]]; then
      echo "file '$file_name' does not exist"
      return 1
    fi

    local file_data=`jq -R -s '.' < "$file_name"`
    local data_length=${#file_data}

    local item="$(get_item "$secret_name")"
    local id=`echo $item | jq -r ".id"`

    if [[ "$id" == "" ]] || [[ "$id" == "null" ]]; then
      echo "Secret '$secret_name' not found"

      if [[ "$data_length" -gt 7500 ]]; then
        if [[ "$dry_run" -eq 1 ]]; then
          echo "[dry-run] Would create '$secret_name' in folder '$folder' as attachment from '$file_name'"
          return 0
        fi

        echo "Creating '$secret_name' in folder '$folder' as attachment"

        local item=`bw get template item | jq ".type=2" | jq ".collectionIds=[]" | jq ".name=\"$secret_name\"" | jq ".notes=\"\"" | jq ".secureNote.type=0" | jq ".folderId=\"$folder_id\"" | bw encode | bw create item`
        local id=`echo $item | jq -r ".id"`

        bw create attachment --file "$file_name" --itemid "$id" > /dev/null
        return 0
      fi

      if [[ "$dry_run" -eq 1 ]]; then
        echo "[dry-run] Would create '$secret_name' in folder '$folder' as note from '$file_name'"
        return 0
      fi

      echo "Creating '$secret_name' in folder '$folder' as note"
      bw get template item | jq ".type=2" | jq ".collectionIds=[]" | jq ".name=\"$secret_name\"" | jq ".folderId=\"$folder_id\"" | jq ".notes=$file_data" | jq ".secureNote.type=0" | bw encode | bw create item > /dev/null
      return 0
    fi

    if [[ "$dry_run" -eq 1 ]]; then
      echo "[dry-run] Would update secret '$secret_name' ($id) from '$file_name'"
      return 0
    fi

    echo "Updating secret '$secret_name' ($id)"
    echo -n "$item" | jq ".notes=$file_data" | bw encode | bw edit item "$id" > /dev/null
    return 0
  }

  sync_by_newest() {
    local secret_name="$1"
    local file_name="$2"

    local item="$(get_item "$secret_name")"
    local id=`echo $item | jq -r ".id"`

    if [[ "$id" == "" ]] || [[ "$id" == "null" ]]; then
      echo "Remote missing for '$secret_name', pushing local file"
      push_one "$secret_name" "$file_name"
      return $?
    fi

    if [[ ! -f "$file_name" ]]; then
      echo "Local file '$file_name' missing, pulling from bitwarden"
      pull_one "$secret_name" "$file_name"
      return $?
    fi

    local local_epoch="$(stat -c %Y "$file_name" 2>/dev/null || echo 0)"
    local remote_revision="$(echo "$item" | jq -r '.revisionDate // .creationDate // empty')"
    local remote_epoch
    remote_epoch="$(date -d "$remote_revision" +%s 2>/dev/null || echo 0)"

    if [[ "$local_epoch" -ge "$remote_epoch" ]]; then
      echo "Local '$file_name' is newer (or same), pushing"
      push_one "$secret_name" "$file_name"
      return $?
    fi

    echo "Remote '$secret_name' is newer, pulling"
    pull_one "$secret_name" "$file_name"
    return $?
  }

  sync_one() {
    local logical_secret_name="$1"
    local file_name="$2"
    local secret_name="SECRET_$logical_secret_name"

    if [[ "$op" == "pull" ]]; then
      pull_one "$secret_name" "$file_name"
      return $?
    fi

    if [[ "$op" == "push" ]]; then
      push_one "$secret_name" "$file_name"
      return $?
    fi

    if [[ "$op" == "sync" ]]; then
      sync_by_newest "$secret_name" "$file_name"
      return $?
    fi
  }

  if [[ -n "$arg_secret_name" ]] && [[ -n "$arg_file_name" ]]; then
    sync_one "$arg_secret_name" "$arg_file_name"
    return 0
  fi

  local config_file="${SYNC_SECRETS_CONFIG:-.sync_secrets.toml}"
  if [[ ! -f "$config_file" ]]; then
    echo "Missing '$config_file'. Provide [secret_name] [file_name] or create config mappings."
    exit 1
  fi

  if ! command -v yq &>/dev/null; then
    echo "Config mode requires 'yq' to parse '$config_file'."
    echo "Install yq or provide [secret_name] [file_name] arguments."
    exit 1
  fi

  local mappings
  mappings="$(parse_sync_config "$config_file")"
  if [[ -z "$mappings" ]]; then
    echo "No secret mappings found in '$config_file'"
    exit 1
  fi

  while IFS=$'\t' read -r mapped_secret_name mapped_file_name; do
    [[ -z "$mapped_secret_name" || -z "$mapped_file_name" ]] && continue
    sync_one "$mapped_secret_name" "$mapped_file_name"
  done <<< "$mappings"
}

if [[ "$op" != "push" ]] && [[ "$op" != "pull" ]] && [[ "$op" != "sync" ]] && [[ "$op" != "list" ]]; then
	help
	exit 1
fi


if command -v bw &> /dev/null ; then
  echo "Bitwarden found"
  bitwarden "$op" "${args[0]:-}" "${args[1]:-}" "$dry_run"
  if [[ "$dry_run" -eq 1 ]]; then
    echo "Dry run complete. No changes were made."
  else
    echo "Secrets succesfully updated :)"
  fi
  exit
fi

echo "No Password Manager found"
exit 1                              
