// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "icon_theme": "Zed (Default)",
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "tsserver": {
            "experimental": {
              "enableProjectDiagnostics": true,
            },
          },
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "cli_default_open_behavior": "new_window",
  "redact_private_values": true,
  "agent_servers": {
    "opencode": {
      "favorite_config_option_values": {
        "model": [
          "gijspt/gijspt.openai/gpt-oss-120b",
          "gijspt/gijspt.google/gemma-4-E4B-it",
        ],
      },
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "tree_view": false,
    "dock": "left",
  },
  "agent": {
    "default_profile": "write",
    "tool_permissions": {
      "tools": {
        "terminal": {
          "default": "allow",
        },
      },
    },
    "dock": "left",
    "default_model": {
      "effort": "high",
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "terminal": {
    "copy_on_select": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "relative_line_numbers": "enabled",
  "sticky_scroll": {
    "enabled": true,
  },
  "vertical_scroll_margin": 10.0,
  "gutter": {
    "line_numbers": true,
  },
  "minimap": {
    "show": "never",
  },
  "buffer_font_fallbacks": [
    "Inconsolata",
    "Monaco",
    "Consolas",
    "Courier New",
    "monospace",
  ],
  "buffer_font_family": "Consolas",
  "file_types": {
    "jsonc": ["*.json"],
  },
  "languages": {
    "TSX": {
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll.eslint": true,
      },
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll.eslint": true,
      },
    },
  },

  "show_edit_predictions": true,
  "edit_predictions": {
    "disabled_globs": ["**/config.toml", "**/config.json", "**/.env"],
  },

  "soft_wrap": "editor_width",
  "tab_size": 2,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "light",
    "light": "VSCode Light Modern",
    "dark": "One Dark",
  },
}
